{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "modules-left": [
        "niri/workspaces",
        "idle_inhibitor",
    ],
    "modules-center": [
        "niri/window"
    ],
    "modules-right": [
        "bluetooth",
        "pulseaudio",
        "battery",
        "tray",
        "clock",
    ],
    "tray": {
        "spacing": 10,
    },
    "niri/window": {
        "all-outputs": true,
        "format": "{title}",
        "align": "center",
        "max-length": 25,
        "min-length": 25
    },
    "niri/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "active": "â€¢",
            "default": "â€¢",
            "urgent": "â€¢"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ïپ® ",
            "deactivated": "ïپ° "
        }
    },
    "bluetooth": {
        "format": "ïٹ”",
        "on-click": "blueberry"
    },
    "clock": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a %b %d  %I:%M %p}",
        "on-click": "swaync-client -t",
    },
    "battery": {
        "interval": 5,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% َ°پ¹",
        "format-plugged": "{capacity}% َ±ک–",
        "format-charging": "{capacity}% َ±گ¥",
        "format-icons": [
            "َ°پ»", // 0-20%
            "َ°پ½", // 21-40%
            "َ°پ؟", // 41-60%
            "َ°‚پ", // 61-80%
            "َ°پ¹" // 81-100%
        ],
        "tooltip-format": "{timeTo} {capacity}%"
    },
    "network": {
        "format-wifi": "ï‡« ",
        "format-ethernet": "{ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "َ°¤®",
        "format-alt": "ï‡« ",
        "on-click": "nm-connection-editor",
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "َ°—؟ {icon}",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": [
                "ï€¦ ",
                "ï€§ ",
                "ï€¨ "
            ]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol"
    }
}
